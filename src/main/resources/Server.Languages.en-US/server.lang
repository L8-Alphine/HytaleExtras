customUI.triggerVolumeEffectEditor.field.set_camera.Locked.tooltip = If true, the player cannot manually switch camera perspective while in this mode. Has no effect when Mode is "reset". Defaults to false.

# =====================================================================
# set_voice_activity
# =====================================================================
customUI.triggerVolumeEffectEditor.field.set_voice_activity.Mode = Mode
customUI.triggerVolumeEffectEditor.field.set_voice_activity.Mode.tooltip = Voice activity action: mute, unmute, or toggle. Defaults to the triggering player unless TargetPlayer is set.
customUI.triggerVolumeEffectEditor.field.set_voice_activity.Mode.placeholder = mute / unmute / toggle
