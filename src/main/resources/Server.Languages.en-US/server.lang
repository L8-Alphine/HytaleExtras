customUI.triggerVolumeEffectEditor.field.set_voice_activity.TargetPlayer.placeholder = e.g. PlayerB

# =====================================================================
# variable_condition
# =====================================================================
customUI.triggerVolumeEffectEditor.field.variable_condition.Key = Variable Name
customUI.triggerVolumeEffectEditor.field.variable_condition.Key.tooltip = The per-player variable to evaluate. The condition fails silently if the variable does not exist and the operator requires a value.
customUI.triggerVolumeEffectEditor.field.variable_condition.Key.placeholder = e.g. zone
customUI.triggerVolumeEffectEditor.field.variable_condition.Operator = Operator
customUI.triggerVolumeEffectEditor.field.variable_condition.Operator.tooltip = Comparison: "equals" / "not_equals" — string match; "greater_than" / "less_than" — numeric comparison; "exists" — passes if the variable is set to any value; "not_exists" — passes if the variable is absent.
customUI.triggerVolumeEffectEditor.field.variable_condition.Operator.placeholder = equals / not_equals / greater_than / less_than / exists / not_exists
customUI.triggerVolumeEffectEditor.field.variable_condition.Operator.option.exists = Exists
customUI.triggerVolumeEffectEditor.field.variable_condition.Operator.option.not_exists = Does Not Exist
customUI.triggerVolumeEffectEditor.field.variable_condition.Operator.option.equals = Equals
customUI.triggerVolumeEffectEditor.field.variable_condition.Operator.option.not_equals = Does Not Equal
customUI.triggerVolumeEffectEditor.field.variable_condition.Operator.option.greater_than = Greater Than
customUI.triggerVolumeEffectEditor.field.variable_condition.Operator.option.less_than = Less Than
customUI.triggerVolumeEffectEditor.field.variable_condition.Value = Compare Value
customUI.triggerVolumeEffectEditor.field.variable_condition.Value.tooltip = Value to compare against. Required for equals, not_equals, greater_than, and less_than. Leave blank for exists and not_exists operators.
customUI.triggerVolumeEffectEditor.field.variable_condition.Value.placeholder = e.g. ruins

# =====================================================================
# cooldown_ready
# =====================================================================
customUI.triggerVolumeEffectEditor.field.cooldown_ready.Name = Cooldown Name
customUI.triggerVolumeEffectEditor.field.cooldown_ready.Name.tooltip = Identifier of the cooldown to check. Passes if no active cooldown with this name exists for the triggering player (expired or never applied). Pair with apply_cooldown using the same name to create a one-shot or rate-limited trigger.
customUI.triggerVolumeEffectEditor.field.cooldown_ready.Name.placeholder = e.g. ruins_intro

# =====================================================================
# is_operator
# =====================================================================
customUI.triggerVolumeEffectEditor.field.is_operator.Permission = Permission
customUI.triggerVolumeEffectEditor.field.is_operator.Permission.tooltip = Optional custom permission string to check. If omitted, the condition checks whether the player is a server operator. If set, it checks for this specific permission instead.
customUI.triggerVolumeEffectEditor.field.is_operator.Permission.placeholder = e.g. myserver.admin
customUI.triggerVolumeEffectEditor.field.is_operator.Invert = Invert
customUI.triggerVolumeEffectEditor.field.is_operator.Invert.tooltip = If true, the condition passes when the player does NOT have the permission. Useful to gate content for non-operators or unprivileged players.

# =====================================================================
# world_time_between
# =====================================================================
customUI.triggerVolumeEffectEditor.field.world_time_between.FromHour = From Hour (0-23)
customUI.triggerVolumeEffectEditor.field.world_time_between.FromHour.tooltip = Start of the active window (inclusive) as a 24-hour integer: 0 = midnight, 6 = dawn, 12 = noon, 18 = dusk. If FromHour is greater than ToHour, the range wraps midnight (e.g. 22 to 5 covers 10 pm through 5 am).
customUI.triggerVolumeEffectEditor.field.world_time_between.ToHour = To Hour (0-23)
customUI.triggerVolumeEffectEditor.field.world_time_between.ToHour.tooltip = End of the active window (inclusive) as a 24-hour integer. Set this lower than FromHour to span midnight (e.g. FromHour=20, ToHour=5 for nighttime).

# =====================================================================
# player_hidden
# =====================================================================
customUI.triggerVolumeEffectEditor.field.player_hidden.TargetPlayer = Target Player
customUI.triggerVolumeEffectEditor.field.player_hidden.TargetPlayer.tooltip = Username of the player whose visibility state to check. Passes if the triggering player currently has this player hidden via player_hide_entity.
customUI.triggerVolumeEffectEditor.field.player_hidden.TargetPlayer.placeholder = e.g. PlayerB
customUI.triggerVolumeEffectEditor.field.player_hidden.Invert = Invert
customUI.triggerVolumeEffectEditor.field.player_hidden.Invert.tooltip = If true, the condition passes when the target is NOT hidden from the triggering player. Use to fire effects the moment a player becomes visible again.

# =====================================================================
# volume_has_tag
# =====================================================================
customUI.triggerVolumeEffectEditor.field.volume_has_tag.TargetVolumeId = Target Volume ID
customUI.triggerVolumeEffectEditor.field.volume_has_tag.TargetVolumeId.tooltip = ID of the volume whose tags to inspect. Leave blank to check the current volume.
customUI.triggerVolumeEffectEditor.field.volume_has_tag.TargetVolumeId.placeholder = e.g. door_lock
customUI.triggerVolumeEffectEditor.field.volume_has_tag.Key = Tag Key
customUI.triggerVolumeEffectEditor.field.volume_has_tag.Key.tooltip = Tag name to look for on the target volume.
customUI.triggerVolumeEffectEditor.field.volume_has_tag.Key.placeholder = e.g. locked
customUI.triggerVolumeEffectEditor.field.volume_has_tag.Value = Tag Value
customUI.triggerVolumeEffectEditor.field.volume_has_tag.Value.tooltip = Optional. If set, the condition only passes when the tag exists AND equals this exact value. Leave blank to pass for any value.
customUI.triggerVolumeEffectEditor.field.volume_has_tag.Value.placeholder = e.g. 1
customUI.triggerVolumeEffectEditor.field.volume_has_tag.Invert = Invert
customUI.triggerVolumeEffectEditor.field.volume_has_tag.Invert.tooltip = If true, passes when the volume does NOT have the specified tag (or value). Useful to trigger effects only after a tag has been cleared.

# =====================================================================
# has_tag
# =====================================================================
customUI.triggerVolumeEffectEditor.field.has_tag.Tag = Tag Name
customUI.triggerVolumeEffectEditor.field.has_tag.Tag.tooltip = Player tag to check. Passes if the triggering player has this persistent tag (set via add_tag). Tags survive server restarts and are per-player.
customUI.triggerVolumeEffectEditor.field.has_tag.Tag.placeholder = e.g. storyline_a_active
customUI.triggerVolumeEffectEditor.field.has_tag.Invert = Invert
customUI.triggerVolumeEffectEditor.field.has_tag.Invert.tooltip = If true, passes when the player does NOT have the tag. Use to check if a player has not yet unlocked something or hasn't been to a location.

